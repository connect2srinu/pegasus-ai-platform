# Mock mode — fully offline, no AWS/Postgres required.
# SQLite database stored locally. All cloud integrations are mocked.
# Copy to .env or pass inline: APP_MODE=mock npm run dev

APP_MODE=mock
DB_TYPE=sqlite
DB_PATH=.guardian-dev.db
USE_REAL_AWS=false
USE_REAL_AGENTCORE=false
USE_REAL_LLM=false
USE_MOCK_IDENTITY=true
PORT=4201
HOST=0.0.0.0

# Customize the seeded org (only applied on first boot when DB is empty):
# SEED_ORG_NAME=My Dev Org
# SEED_ORG_EMAIL=me@example.com
