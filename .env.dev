# Connected dev mode — real Postgres + real AWS/AgentCore/LLM.
# Requires valid AWS credentials and a reachable Postgres instance.

APP_MODE=dev
DB_TYPE=postgres
DB_URL=postgres://postgres:postgres@localhost:5432/guaistudio
USE_REAL_AWS=true
USE_REAL_AGENTCORE=true
USE_REAL_LLM=true
USE_MOCK_IDENTITY=false
PORT=4201
HOST=0.0.0.0
AWS_REGION=us-east-1
