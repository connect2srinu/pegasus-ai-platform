{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guardian.example.com/schemas/portable-agent-spec.schema.json",
  "title": "Guardian Portable Agent Specification",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "projectId", "owner", "agentType", "runtime", "model"],
  "properties": {
    "schemaVersion": {
      "const": "guardian.agent/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,62}$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "projectId": {
      "type": "string"
    },
    "owner": {
      "type": "object",
      "required": ["userId", "businessUnit"],
      "properties": {
        "userId": {
          "type": "string"
        },
        "businessUnit": {
          "type": "string"
        }
      }
    },
    "agentType": {
      "type": "string",
      "enum": ["bedrock_agentcore", "langgraph", "openai_agent", "crewai", "strands", "custom"]
    },
    "runtime": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "target": {
          "type": "string",
          "enum": ["agentcore", "external", "future"]
        },
        "entrypoint": {
          "type": "string"
        }
      }
    },
    "model": {
      "type": "object",
      "required": ["provider", "modelId"],
      "properties": {
        "provider": {
          "type": "string"
        },
        "modelId": {
          "type": "string"
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["toolId", "version"],
        "properties": {
          "toolId": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "requiredScopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "knowledge": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["knowledgeBaseId"],
        "properties": {
          "knowledgeBaseId": {
            "type": "string"
          }
        }
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "shortTerm": {
          "type": "boolean"
        },
        "longTerm": {
          "type": "boolean"
        }
      }
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["secretRef", "usage"],
        "properties": {
          "secretRef": {
            "type": "string"
          },
          "usage": {
            "type": "string"
          }
        }
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "arizeProject": {
          "type": "string"
        },
        "traceLevel": {
          "type": "string",
          "enum": ["minimal", "standard", "enhanced"]
        }
      }
    },
    "extensions": {
      "type": "object",
      "properties": {
        "crewai": {
          "type": "object",
          "properties": {
            "crewName": {
              "type": "string"
            },
            "agents": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "strands": {
          "type": "object",
          "properties": {
            "agentName": {
              "type": "string"
            },
            "entrypoint": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
