{
  "name": "guardian-ai-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api": "HOST=0.0.0.0 node scripts/static-server.cjs",
    "api:mock": "APP_MODE=mock HOST=0.0.0.0 node scripts/server.cjs",
    "api:local": "APP_MODE=local HOST=0.0.0.0 node scripts/server.cjs",
    "api:dev": "APP_MODE=dev HOST=0.0.0.0 node scripts/server.cjs",
    "dev:mock": "concurrently \"npm run api:mock\" \"npm run dev\"",
    "dev:local": "concurrently \"npm run api:local\" \"npm run dev\"",
    "dev:connected": "concurrently \"npm run api:dev\" \"npm run dev\"",
    "seed": "APP_MODE=mock node backend/runtime/db/seed.cjs",
    "seed:reset": "rm -f .guardian-dev.db && APP_MODE=mock node backend/runtime/db/seed.cjs",
    "test": "node --test tests/mock-mode.test.cjs tests/api.test.cjs",
    "test:unit": "node --test tests/mock-mode.test.cjs",
    "test:api": "node --test tests/api.test.cjs",
    "test:watch": "node --test --watch tests/mock-mode.test.cjs tests/api.test.cjs",
    "build": "node --test tests/mock-mode.test.cjs tests/api.test.cjs && vite build",
    "preview": "vite preview",
    "check": "vite build"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.1075.0",
    "@aws-sdk/client-bedrock": "^3.1075.0",
    "@aws-sdk/client-bedrock-agentcore": "^3.1075.0",
    "@aws-sdk/client-bedrock-agentcore-control": "^3.1075.0",
    "@aws-sdk/client-iam": "^3.1075.0",
    "@aws-sdk/client-lambda": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/client-sts": "^3.1075.0",
    "@aws-sdk/credential-providers": "^3.1075.0",
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.2.0",
    "lucide-react": "^0.561.0",
    "pg": "^8.22.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^5.4.21"
  }
}
