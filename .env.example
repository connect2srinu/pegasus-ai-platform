VITE_PLATFORM_NAME=

# ── Local single-account AWS testing mode ─────────────────────────────────────
# Set LOCAL_AWS_MODE=true to use real AWS credentials from ~/.aws/credentials.
# The server will call STS GetCallerIdentity at startup to resolve the account ID
# and populate org awsConfig automatically. No account IDs need to be hardcoded.
#
# Credentials are read from the default AWS provider chain:
#   1. AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY environment variables
#   2. AWS_PROFILE (named profile in ~/.aws/credentials)
#   3. [default] profile in ~/.aws/credentials
#   4. EC2/ECS instance metadata
LOCAL_AWS_MODE=
AWS_REGION=
AWS_PROFILE=
